---
import { howToSchema, type HowToInput } from "~/lib/schema";

interface Props extends HowToInput {
  emitSchema?: boolean;
}

const { name, description, steps, totalTime, emitSchema = true } = Astro.props as Props;
---

<section class="howto" aria-labelledby="howto-heading">
  <h2 id="howto-heading">{name}</h2>
  {description && <p class="howto-desc">{description}</p>}
  <ol class="howto-steps">
    {steps.map((s, i) => (
      <li>
        <div class="step-num" aria-hidden="true">{i + 1}</div>
        <div class="step-body">
          <p class="step-name">{s.name}</p>
          <p class="step-text">{s.text}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

{emitSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema({ name, description, steps, totalTime }))} />
)}

<style>
  .howto { margin: var(--space-10) 0; }
  .howto h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
  }
  .howto-desc {
    color: var(--color-fg-muted);
    margin-bottom: var(--space-5);
  }
  .howto-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .howto-steps li {
    display: flex;
    gap: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
  }
  .step-num {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-pill);
    background: var(--color-brand);
    color: var(--color-brand-fg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--text-sm);
  }
  .step-name {
    font-weight: 600;
    color: var(--color-fg);
    margin-bottom: var(--space-1);
  }
  .step-text {
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
  }
</style>
