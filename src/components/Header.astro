---
import { SITE, NAV_PRIMARY } from "~/data/site.config";
const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label={`${SITE.name} - beranda`}>
      <span class="brand-mark" aria-hidden="true">i</span>
      <span class="brand-text">{SITE.name}</span>
    </a>
    <nav aria-label="Navigasi utama" class="nav">
      <ul>
        {NAV_PRIMARY.map((item) => {
          const isActive = pathname === item.href || (item.href !== "/" && pathname.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                aria-current={isActive ? "page" : undefined}
                class:list={["nav-link", isActive && "is-active"]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
    <button
      type="button"
      class="nav-toggle"
      aria-label="Buka menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-nav-toggle
    >
      <span></span><span></span><span></span>
    </button>
  </div>
  <div id="mobile-menu" class="mobile-menu" hidden>
    <ul>
      {NAV_PRIMARY.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: var(--shadow-xs);
  }
  .header-inner {
    max-width: var(--container-page);
    margin: 0 auto;
    padding: var(--space-3) var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-fg);
    font-weight: 700;
    font-size: var(--text-base);
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-md);
    background: var(--color-brand);
    color: var(--color-brand-fg);
    font-weight: 800;
    font-family: var(--font-display);
  }
  .brand-text {
    line-height: var(--leading-tight);
  }
  .nav {
    margin-left: auto;
  }
  .nav ul {
    display: flex;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    color: var(--color-fg-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--motion-fast) var(--ease-standard),
      background var(--motion-fast) var(--ease-standard);
  }
  .nav-link:hover {
    color: var(--color-fg);
    background: var(--color-bg-subtle);
  }
  .nav-link.is-active {
    color: var(--color-fg);
    background: var(--color-brand-soft);
  }
  .nav-toggle {
    display: none;
    margin-left: auto;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-2);
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
  }
  .nav-toggle span {
    display: block;
    width: 1.25rem;
    height: 2px;
    background: var(--color-fg);
    border-radius: var(--radius-pill);
  }
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: var(--space-2) var(--space-4);
  }
  .mobile-menu li a {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding: var(--space-3) var(--space-2);
    color: var(--color-fg);
    text-decoration: none;
    font-size: var(--text-base);
    border-bottom: 1px solid var(--color-border);
  }
  .mobile-menu li:last-child a {
    border-bottom: none;
  }

  @media (max-width: 820px) {
    .nav { display: none; }
    .nav-toggle { display: inline-flex; }
    .mobile-menu[data-open="true"] { display: block; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = menu.dataset.open === "true";
      menu.dataset.open = isOpen ? "false" : "true";
      menu.hidden = isOpen;
      toggle.setAttribute("aria-expanded", String(!isOpen));
    });
  }
</script>
