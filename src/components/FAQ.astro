---
import { faqSchema, type FAQItem } from "~/lib/schema";

interface Props {
  items: FAQItem[];
  heading?: string;
  emitSchema?: boolean;
}

const { items, heading = "Pertanyaan yang sering ditanyakan", emitSchema = true } = Astro.props as Props;
---

<section class="faq" aria-labelledby="faq-heading">
  <h2 id="faq-heading">{heading}</h2>
  <div class="faq-list">
    {items.map((item, i) => (
      <details class="faq-item" name="faq" open={i === 0}>
        <summary>
          <span class="faq-q">{item.question}</span>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <div class="faq-a">
          <p set:html={item.answer.replace(/\n\n/g, "</p><p>")} />
        </div>
      </details>
    ))}
  </div>
</section>

{emitSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(items))} />
)}

<style>
  .faq {
    margin: var(--space-12) 0;
  }
  .faq h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    letter-spacing: -0.01em;
  }
  .faq-list {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
  }
  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }
  .faq-item:last-child {
    border-bottom: none;
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    font-weight: 600;
    color: var(--color-fg);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary:hover { background: var(--color-bg-subtle); }
  .faq-icon {
    font-size: var(--text-xl);
    color: var(--color-fg-muted);
    transition: transform var(--motion-base) var(--ease-standard);
    flex-shrink: 0;
  }
  .faq-item[open] .faq-icon { transform: rotate(45deg); }
  .faq-a {
    padding: 0 var(--space-5) var(--space-5);
    color: var(--color-fg-muted);
    line-height: var(--leading-relaxed);
  }
  .faq-a p { margin-bottom: var(--space-3); }
  .faq-a p:last-child { margin-bottom: 0; }
</style>
