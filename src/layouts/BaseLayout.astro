---
import "~/styles/globals.css";
import { SITE } from "~/data/site.config";
import { resolveSEO, type SEOInput } from "~/lib/seo";
import { websiteSchema } from "~/lib/schema";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import Analytics from "~/components/Analytics.astro";
import ConsentBanner from "~/components/ConsentBanner.astro";
import EventTracking from "~/components/EventTracking.astro";

interface Props {
  seo: SEOInput;
  jsonLd?: unknown[]; // additional JSON-LD blocks (article, FAQ, HowTo, Breadcrumb)
}

const { seo, jsonLd = [] } = Astro.props as Props;
const r = resolveSEO(seo);
const allJsonLd = [websiteSchema(), ...jsonLd];
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{r.fullTitle}</title>
    <meta name="description" content={r.description} />
    <link rel="canonical" href={r.canonical} />
    {r.noindex && <meta name="robots" content="noindex,nofollow" />}
    {!r.noindex && <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />}

    <meta name="theme-color" content={SITE.themeColor} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {r.keywords && r.keywords.length > 0 && (
      <meta name="keywords" content={r.keywords.join(", ")} />
    )}

    {/* Open Graph */}
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={r.fullTitle} />
    <meta property="og:description" content={r.description} />
    <meta property="og:url" content={r.canonical} />
    <meta property="og:type" content={r.ogType} />
    {r.ogImage && <meta property="og:image" content={r.ogImage} />}
    <meta property="og:locale" content={SITE.locale.replace("-", "_")} />
    {r.publishedTime && <meta property="article:published_time" content={r.publishedTime} />}
    {r.modifiedTime && <meta property="article:modified_time" content={r.modifiedTime} />}

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={r.fullTitle} />
    <meta name="twitter:description" content={r.description} />
    {r.ogImage && <meta name="twitter:image" content={r.ogImage} />}

    {/* JSON-LD */}
    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <Analytics />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Lompat ke konten</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ConsentBanner />
    <EventTracking />
    <slot name="body-end" />
  </body>
</html>
