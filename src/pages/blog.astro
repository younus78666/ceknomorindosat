---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import { listPosts } from "~/data/internal-links";
import { SITE } from "~/data/site.config";
import { webPageSchema } from "~/lib/schema";

const posts = listPosts();
const slug = "blog";
const h1 = "Blog Panduan Indosat IM3";

const seo = {
  title: "Blog Panduan Indosat IM3",
  noSuffix: true,
  description:
    "Tulisan analitis dan troubleshoot seputar layanan Indosat IM3: kode dial yang berubah, penyebab cek nomor gagal, dan perbedaan IM3 dengan Indosat.",
  canonicalPath: `/${slug}`,
  type: "website" as const,
  publishedTime: "2026-05-04",
  modifiedTime: "2026-05-04",
};

const url = `${SITE.url}/${slug}`;
const pageJsonLd = [
  webPageSchema({
    type: "CollectionPage",
    name: h1,
    description: seo.description,
    url,
    datePublished: "2026-05-04",
    dateModified: "2026-05-04",
  }),
];

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString("id-ID", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<BaseLayout seo={seo} jsonLd={pageJsonLd}>
  <article class="blog">
    <div class="blog-inner">
      <Breadcrumbs items={[{ name: "Beranda", href: "/" }, { name: "Blog" }]} />
      <header>
        <p class="kicker">Blog</p>
        <h1>{h1}</h1>
        <p class="lead">
          Tulisan analitis seputar perubahan kode dial, troubleshoot cek nomor,
          dan latar belakang merger Indosat IM3.
        </p>
      </header>

      <ul class="post-list">
        {posts.map((p) => (
          <li>
            <a href={`/${p.slug}`} class="post-card">
              <h2>{p.title}</h2>
              <p class="post-desc">{p.description}</p>
              <p class="post-meta">
                <time datetime={p.publishedAt}>
                  {p.publishedAt ? formatDate(p.publishedAt) : ""}
                </time>
              </p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </article>
</BaseLayout>

<style>
  .blog { background: var(--color-bg); }
  .blog-inner {
    max-width: var(--container-prose);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-12);
  }
  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-3);
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, var(--text-4xl));
    font-weight: 800;
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .lead {
    color: var(--color-fg-muted);
    font-size: var(--text-lg);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
  }
  .post-card {
    display: block;
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color var(--motion-fast) var(--ease-standard),
      box-shadow var(--motion-fast) var(--ease-standard);
  }
  .post-card:hover {
    border-color: var(--color-brand-strong);
    box-shadow: var(--shadow-sm);
  }
  .post-card h2 {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-fg);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
  }
  .post-desc {
    color: var(--color-fg-muted);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-2);
  }
  .post-meta {
    color: var(--color-fg-subtle);
    font-size: var(--text-sm);
    margin: 0;
  }
</style>
